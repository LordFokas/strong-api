{
	"compilerOptions": {
		"esModuleInterop": true,
		"rootDir": "./src",
		"outDir": "./dist",
		"declaration": true,

		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"target": "es2022",
		"lib": ["ES2022", "DOM"],

		"useDefineForClassFields": true,
		"noImplicitAny": true,
		"skipLibCheck": true,
	},
	"files": [
		"src/client.ts",
		"src/server.ts"
	]
}